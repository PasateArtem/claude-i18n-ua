{
  "manifest_version": 3,
  "name": "Claude Ukrainian",
  "description": "Українська локалізація інтерфейсу Claude.ai",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://claude-i18n-ua.netlify.app/*"
  ],
  "background": {
    "service_worker": "service.js"
  },
  "content_scripts": [
    {
      "js": ["script.js"],
      "run_at": "document_start",
      "matches": ["https://claude.ai/*"]
    },
    {
      "js": ["hook.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "matches": ["https://claude.ai/*"]
    }
  ],
  "action": {
    "default_icon": "assets/logo.128x.png",
    "default_title": "Claude Ukrainian"
  },
  "icons": {
    "16": "assets/logo.16x.png",
    "32": "assets/logo.32x.png",
    "48": "assets/logo.48x.png",
    "128": "assets/logo.128x.png"
  }
}
